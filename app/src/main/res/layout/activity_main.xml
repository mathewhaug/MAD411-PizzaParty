<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- Number of people? -->
    <TextView
        android:id="@+id/label_people"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Number of people?"
        android:textSize="20sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/num_attend_edit_text"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="10"
        android:ems="5"
        android:minHeight="48dp"
        android:importantForAutofill="no" />

    <!-- How hungry? -->
    <TextView
        android:id="@+id/label_hungry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How hungry?"
        android:textSize="20sp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/hungry_radio_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/light_radio_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Light" />

        <RadioButton
            android:id="@+id/medium_radio_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medium"
            android:checked="true"
            android:layout_marginStart="8dp" />

        <RadioButton
            android:id="@+id/ravenous_radio_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ravenous"
            android:layout_marginStart="8dp" />
    </RadioGroup>

    <!-- Total pizzas -->
    <TextView
        android:id="@+id/num_pizzas_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total pizzas: 0"
        android:textSize="20sp"
        android:layout_marginTop="20dp" />

    <!-- Calculate button -->
    <Button
        android:id="@+id/calc_button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Calculate"
        android:layout_marginTop="20dp"
        android:textAllCaps="false" />

</LinearLayout>
